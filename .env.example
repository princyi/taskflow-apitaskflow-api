# --- Database ---
# Local dev (docker-compose):
DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow
# Production (AWS RDS) example:
# DATABASE_URL=postgresql://taskflow:STRONG_PASSWORD@taskflow-db.xxxxxxxx.us-east-1.rds.amazonaws.com:5432/taskflow

# --- Auth ---
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- AWS S3 (task attachments) ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=taskflow-attachments-yourname

# --- App ---
ENVIRONMENT=development
